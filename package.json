		"@eslint/js": "10.0.1",
		"@iconify-json/fluent": "1.2.43",
		"@iconify-json/fluent-emoji": "1.2.7",
		"@iconify-json/logos": "1.2.11",
		"@iconify/svelte": "5.2.1",
		"@oslojs/oauth2": "0.5.0",
		"@sveltejs/adapter-vercel": "6.3.3",
		"@sveltejs/kit": "2.55.0",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/forms": "0.5.11",
