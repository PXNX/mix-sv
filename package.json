		"eslint": "10.1.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.16.0",
		"globals": "17.4.0",
		"postgres": "3.4.8",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.7.2",
